{
    "name": "firelink",
    "version": "0.1.1",
    "description": "A relational integrity layer on top of Firebase Firestore",
    "license": "MIT",
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./server": "./dist/server/index.js",
        "./client": "./dist/client/index.js",
        "./types": "./dist/shared/types.js"
    },
    "bin": {
        "firelink": "dist/cli/index.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.json --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" \"*.json\" \"*.mjs\" && eslint src/ tests/ --fix",
        "lint:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" && eslint src/ tests/"
    },
    "dependencies": {
        "commander": "^12.0.0",
        "drizzle-orm": "^0.30.0",
        "express": "^4.18.0",
        "node-fetch": "^3.3.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.0",
        "@types/express": "^4.17.0",
        "@types/node": "^20.0.0",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.2",
        "better-sqlite3": "^12.8.0",
        "drizzle-kit": "^0.21.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "firebase-admin": "^12.7.0",
        "firebase-tools": "^15.12.0",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.1.2"
    },
    "peerDependencies": {
        "better-sqlite3": ">=9.0.0",
        "firebase": ">=10.0.0",
        "firebase-admin": ">=12.0.0",
        "mysql2": ">=3.0.0",
        "pg": ">=8.0.0"
    },
    "peerDependenciesMeta": {
        "better-sqlite3": {
            "optional": true
        },
        "firebase": {
            "optional": true
        },
        "mysql2": {
            "optional": true
        },
        "pg": {
            "optional": true
        }
    }
}
